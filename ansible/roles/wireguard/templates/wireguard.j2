[Interface]
PrivateKey = {{ wireguard_private_key.stdout }}
Address = {% if ansible_facts['hostname'] in groups['vps'] %}10.0.0.1/24
{% else %}10.0.0.2/24
{% endif %}
{% if ansible_facts['hostname'] in groups['vps'] %}
ListenPort = 51820
{% endif %}

{% if ansible_facts['hostname'] in groups['vps'] %}
[Peer]
PublicKey = {{ hostvars[groups['gateway'][0]].wireguard_public_key.stdout }}
AllowedIPs = 10.0.0.2/32

{% for peer in wireguard_road_warriors %}
[Peer]
# {{ peer.name }}
PublicKey = {{ peer.public_key }}
AllowedIPs = {{ peer.allowed_ip }}

{% endfor %}
{% else %}
[Peer]
PublicKey = {{ hostvars[groups['vps'][0]].wireguard_public_key.stdout }}
Endpoint = {{ hostvars[groups['vps'][0]].ansible_facts['default_ipv4'].address }}:51820
AllowedIPs = 10.0.0.0/24
{% endif %}
{% if ansible_facts['hostname'] in groups['gateway'] %}
PersistentKeepalive = 25
{% endif %}
